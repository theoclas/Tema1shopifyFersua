[
  {
    "name": "theme_info",
    "theme_name": "ALLSET JEWELRY",
    "theme_version": "1.0.0",
    "theme_author": "ALLSET",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://help.shopify.com/"
  },
  {
    "name": "Logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo image"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 50,
        "max": 250,
        "step": 5,
        "unit": "px",
        "label": "Logo width",
        "default": 120
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_background",
        "label": "Background",
        "default": "#F5F5F0"
      },
      {
        "type": "color",
        "id": "color_foreground",
        "label": "Text",
        "default": "#000000"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent (gold)",
        "default": "#C9A74E"
      },
      {
        "type": "color",
        "id": "color_muted",
        "label": "Muted text",
        "default": "#6B6B6B"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "type_heading_font",
        "default": "cormorant_garamond_n4",
        "label": "Heading font"
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "default": "inter_n4",
        "label": "Body font"
      }
    ]
  },
  {
    "name": "Currency",
    "settings": [
      {
        "type": "checkbox",
        "id": "currency_code_enabled",
        "label": "Show currency codes with prices",
        "default": false
      }
    ]
  },
  {
    "name": "Social & footer",
    "settings": [
      {
        "type": "text",
        "id": "social_instagram",
        "label": "Instagram URL"
      },
      {
        "type": "text",
        "id": "social_pinterest",
        "label": "Pinterest URL"
      },
      {
        "type": "text",
        "id": "social_tiktok",
        "label": "TikTok URL"
      },
      {
        "type": "richtext",
        "id": "footer_note",
        "label": "Footer note",
        "default": "<p>Handcrafted with intention.</p>"
      }
    ]
  }
]

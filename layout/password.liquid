{%- comment -%}
  Layout para la pantalla de contraseña (preview de tienda).
{%- endcomment -%}
<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#000000">
    <title>{{ shop.name }}</title>
    {{ content_for_header }}
    {%- liquid
      assign pwd_body_bold = nil
      if settings.type_body_font != blank
        assign pwd_body_bold = settings.type_body_font | font_modify: 'weight', 'bold'
      endif
    -%}
    {% style %}
      {% if settings.type_body_font != blank %}
        {{ settings.type_body_font | font_face: font_display: 'swap' }}
      {% endif %}
      {% if settings.type_heading_font != blank %}
        {{ settings.type_heading_font | font_face: font_display: 'swap' }}
      {% endif %}
      {% if pwd_body_bold %}{{ pwd_body_bold | font_face: font_display: 'swap' }}{% endif %}
    {% endstyle %}
    {{ 'allset-base.css' | asset_url | stylesheet_tag }}
    {% render 'css-variables' %}
  </head>
  <body class="allset-body template-password">
    {{ content_for_layout }}
    <script src="{{ 'allset-theme.js' | asset_url }}" defer></script>
  </body>
</html>

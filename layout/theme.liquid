{%- comment -%}
  ALLSET JEWELRY — Layout principal
  Carga estilos, scripts y el área donde Shopify inyecta las secciones (JSON templates).
{%- endcomment -%}
<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#000000">
    <link rel="canonical" href="{{ canonical_url }}">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; {{ 'general.meta.tags' | t: tags: current_tags | join: ', ' }}{% endif -%}
      {%- if current_page != 1 %} &ndash; {{ 'general.meta.page' | t: page: current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'meta-tags' %}

    {{ content_for_header }}

    {%- liquid
      assign allset_body_bold = nil
      assign allset_body_italic = nil
      if settings.type_body_font != blank
        assign allset_body_bold = settings.type_body_font | font_modify: 'weight', 'bold'
        assign allset_body_italic = settings.type_body_font | font_modify: 'style', 'italic'
      endif
    -%}
    {% style %}
      {% if settings.type_body_font != blank %}
        {{ settings.type_body_font | font_face: font_display: 'swap' }}
      {% endif %}
      {% if settings.type_heading_font != blank %}
        {{ settings.type_heading_font | font_face: font_display: 'swap' }}
      {% endif %}
      {% if allset_body_bold %}{{ allset_body_bold | font_face: font_display: 'swap' }}{% endif %}
      {% if allset_body_italic %}{{ allset_body_italic | font_face: font_display: 'swap' }}{% endif %}
    {% endstyle %}

    {{ 'allset-base.css' | asset_url | stylesheet_tag }}
    {% render 'css-variables' %}
  </head>

  <body class="allset-body template-{{ template.name }}{% if template.suffix %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">
    <a class="allset-skip-link" href="#MainContent">{{ 'accessibility.skip_to_content' | t }}</a>

    <div class="allset-page" id="PageContainer">
      <main id="MainContent" class="allset-main" role="main" tabindex="-1">
        {{ content_for_layout }}
      </main>
    </div>

    <ul hidden>
      <li id="a11y-refresh-page-message">{{ 'accessibility.refresh_page' | t }}</li>
    </ul>

    <script>
      document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
    </script>
    <script src="{{ 'allset-theme.js' | asset_url }}" defer></script>
  </body>
</html>

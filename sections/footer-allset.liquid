{%- comment -%}
  Pie minimalista: enlaces, redes y nota de marca.
{%- endcomment -%}

<footer class="allset-footer" role="contentinfo">
  <div class="allset-container">
    <div class="allset-footer__grid">
      <div>
        <p class="allset-footer__brand">{{ section.settings.brand_title | default: shop.name | escape }}</p>
        {%- if settings.footer_note != blank -%}
          <div class="allset-footer__note rte">{{ settings.footer_note }}</div>
        {%- endif -%}
      </div>

      {%- if section.settings.menu != blank -%}
        <div>
          <p class="allset-footer__title">{{ section.settings.menu_title | escape }}</p>
          <ul class="allset-footer__links">
            {%- for link in section.settings.menu.links -%}
              <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      <div>
        <p class="allset-footer__title">{{ section.settings.social_title | escape }}</p>
        <div class="allset-social">
          {%- if settings.social_instagram != blank -%}
            <a href="{{ settings.social_instagram }}" rel="noopener" target="_blank" aria-label="Instagram">
              Instagram
            </a>
          {%- endif -%}
          {%- if settings.social_pinterest != blank -%}
            <a href="{{ settings.social_pinterest }}" rel="noopener" target="_blank" aria-label="Pinterest">
              Pinterest
            </a>
          {%- endif -%}
          {%- if settings.social_tiktok != blank -%}
            <a href="{{ settings.social_tiktok }}" rel="noopener" target="_blank" aria-label="TikTok">
              TikTok
            </a>
          {%- endif -%}
        </div>
      </div>
    </div>

    <div class="allset-footer__bottom">
      <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name | escape }}</span>
      <span class="allset-footer__policies">
        {%- if shop.privacy_policy -%}
          <a href="{{ shop.privacy_policy.url }}">{{ shop.privacy_policy.title | escape }}</a>
        {%- endif -%}
        {%- if shop.privacy_policy and shop.refund_policy %} · {% endif -%}
        {%- if shop.refund_policy -%}
          <a href="{{ shop.refund_policy.url }}">{{ shop.refund_policy.title | escape }}</a>
        {%- endif -%}
        {%- if shop.refund_policy and shop.terms_of_service %} · {% endif -%}
        {%- if shop.terms_of_service -%}
          <a href="{{ shop.terms_of_service.url }}">{{ shop.terms_of_service.title | escape }}</a>
        {%- endif -%}
      </span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer (ALLSET)",
  "class": "section-footer-allset",
  "settings": [
    {
      "type": "text",
      "id": "brand_title",
      "label": "Brand line",
      "default": "ALLSET JEWELRY"
    },
    {
      "type": "text",
      "id": "menu_title",
      "label": "Menu column title",
      "default": "Explore"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Footer menu"
    },
    {
      "type": "text",
      "id": "social_title",
      "label": "Social column title",
      "default": "Follow"
    }
  ]
}
{% endschema %}

{%- comment -%}
  Hero editorial a pantalla completa con tagline de marca.
{%- endcomment -%}

<section class="allset-hero">
  <div class="allset-hero__media">
    {%- if section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 2400
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          sizes: '100vw',
          widths: '750, 1100, 1500, 2000, 2400',
          alt: section.settings.image.alt | default: section.settings.heading | escape
      }}
    {%- else -%}
      <div style="width:100%;height:100%;background:linear-gradient(145deg,#1a1a1a,#000);" aria-hidden="true"></div>
    {%- endif -%}
  </div>
  <div class="allset-hero__overlay" aria-hidden="true"></div>

  <div class="allset-container allset-hero__content">
    {%- if section.settings.eyebrow != blank -%}
      <p class="allset-eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}
    <h1 class="allset-hero__tagline">{{ section.settings.heading | escape }}</h1>
    {%- if section.settings.subheading != blank -%}
      <p class="allset-hero__sub">{{ section.settings.subheading | escape }}</p>
    {%- endif -%}
    {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
      <a class="allset-btn allset-btn--inverse" href="{{ section.settings.button_link }}">
        {{ section.settings.button_label | escape }}
        {% render 'icon-arrow' %}
      </a>
    {%- endif -%}
  </div>
</section>

{% style %}
  #shopify-section-{{ section.id }} .allset-hero {
    min-height: {{ section.settings.min_height }}vh;
  }
{% endstyle %}

{% schema %}
{
  "name": "Hero editorial",
  "tag": "section",
  "class": "section-hero-editorial",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "ALLSET JEWELRY"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Más que una joya, es presencia"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Piezas atemporales para el día a día y los momentos que importan."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Descubrir la colección"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 50,
      "max": 100,
      "step": 1,
      "unit": "vh",
      "label": "Minimum height (visual)",
      "default": 78
    }
  ],
  "presets": [
    {
      "name": "Hero editorial"
    }
  ]
}
{% endschema %}

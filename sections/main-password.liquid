{%- comment -%}
  Pantalla de contraseña de la tienda — alineada con la marca.
{%- endcomment -%}

<div class="allset-password" style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:2rem;background:var(--allset-bg);color:var(--allset-fg);">
  <div style="max-width:22rem;width:100%;text-align:center;">
    <p class="allset-header__logo-text" style="margin-bottom:2rem;">{{ shop.name | upcase }}</p>
    {% form 'storefront_password', class: 'allset-password-form' %}
      {{ form.errors | default_errors }}
      <label class="allset-product__label" for="allset-storefront-password" style="text-align:left;">{{ 'general.password_page.password' | t }}</label>
      <input class="allset-qty" type="password" name="password" id="allset-storefront-password" style="width:100%;max-width:none;margin-bottom:1rem;" autocomplete="current-password">
      <button type="submit" class="allset-btn allset-btn--gold" style="width:100%;">{{ 'general.password_page.submit' | t }}</button>
    {% endform %}
  </div>
</div>

{% schema %}
{
  "name": "Password",
  "settings": []
}
{% endschema %}

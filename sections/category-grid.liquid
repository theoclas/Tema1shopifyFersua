{%- comment -%}
  Categorías visuales — bloques con imagen y enlace.
{%- endcomment -%}

<section class="allset-section allset-section--tight" id="section-{{ section.id }}">
  <div class="allset-container">
    <header class="allset-fc__head">
      {%- if section.settings.eyebrow != blank -%}
        <p class="allset-eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      <h2 class="allset-heading allset-heading--lg">{{ section.settings.title | escape }}</h2>
    </header>

    <div class="allset-cat-grid">
      {%- for block in section.blocks -%}
        <a class="allset-cat-card" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 800
              | image_tag:
                loading: 'lazy',
                class: 'allset-cat-card__img',
                sizes: '(min-width: 750px) 25vw, 50vw',
                widths: '375, 550, 750, 800',
                alt: block.settings.image.alt | default: block.settings.title | escape
            }}
          {%- else -%}
            <div class="allset-cat-card__img" style="background:#2a2a2a;min-height:100%;" aria-hidden="true"></div>
          {%- endif -%}
          <span class="allset-cat-card__overlay" aria-hidden="true"></span>
          <span class="allset-cat-card__label">{{ block.settings.title | escape }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Category grid",
  "tag": "section",
  "class": "section-category-grid",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Shop by category"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Categorías"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Cadenas"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category grid",
      "blocks": [
        { "type": "category", "settings": { "title": "Cadenas" } },
        { "type": "category", "settings": { "title": "Anillos" } },
        { "type": "category", "settings": { "title": "Pulseras" } },
        { "type": "category", "settings": { "title": "Pendientes" } }
      ]
    }
  ]
}
{% endschema %}
